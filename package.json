{
  "name": "robotlyne-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run sync",
    "build:deploy": "next build && npm run sync && npm run deploy:worker",
    "sync": "npx ts-node --project tsconfig.scripts.json scripts/sync-content.ts",
    "deploy:worker": "cd cloudflare-worker && npx wrangler deploy",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@supabase/supabase-js": "^2.104.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "dotenv": "^16.6.1",
    "postcss": "^8",
    "supabase": "^2.10.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wrangler": "^4.84.1"
  }
}
